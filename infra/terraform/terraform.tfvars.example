project_name            = "beautycx"
aws_region              = "ap-northeast-1"
github_repo_id          = "YOUR_GITHUB_USER_OR_ORG/beautyCX"
github_branch           = "main"
codestar_connection_arn = "arn:aws:codestar-connections:ap-northeast-1:123456789012:connection/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Small-project default: one Fargate task running both web and api containers.
ecs_desired_count = 1
ecs_task_cpu      = 512
ecs_task_memory   = 1024
