# GitHub Actions 部署到 EC2 時會在遠端產生 .env。
# 這份檔案只作為本機或人工部署範本，不要填入真實 secret 後 commit。

BACKEND_IMAGE=ghcr.io/YOUR_ACCOUNT/beautycx-backend:latest
FRONTEND_IMAGE=ghcr.io/YOUR_ACCOUNT/beautycx-frontend:latest
HTTP_PORT=80

SECRET_KEY=change-me
DATABASE_PATH=/app/data/beautycx.sqlite
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# 原專案仍保留 S3 / CloudFront 圖片服務設定；SQLite demo 可先使用預設值。
AWS_REGION=ap-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=product-images
CLOUDFRONT_DOMAIN=cdn.example.com
API_GATEWAY_URL=
