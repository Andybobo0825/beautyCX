# 本機展示用預設值。不要將正式環境秘密寫入 .env。
NODE_ENV=development
API_PORT=8080
WEB_PORT=3000
CORS_ORIGIN=http://localhost:3000

# SQLite snapshot 路徑。Docker image 內使用 /app/data/beautycx.sqlite。
DATABASE_PATH=data/beautycx.sqlite

# Frontend build-time API path. In Compose, Nginx proxies /api to the API container.
VITE_API_BASE_URL=/api
